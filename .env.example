# ═══════════════════════════════════════════════════════════════════
# Universidad X — Variables de entorno (.env.example)
# Copia este archivo a .env y rellena los valores reales
# NUNCA commitear .env con valores reales
# ═══════════════════════════════════════════════════════════════════

# ── Base de datos ────────────────────────────────────────────────────
POSTGRES_DB=universidadx
POSTGRES_USER=ux_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=5432

MONGO_DB=universidadx
MONGO_USER=ux_admin
MONGO_PASSWORD=CHANGE_ME
MONGO_PORT=27017

REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6379

# ── Secretos JWT (mínimo 32 caracteres) ──────────────────────────────
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_REQUIRED_HERE

# ── NextAuth.js ───────────────────────────────────────────────────────
NEXTAUTH_SECRET=CHANGE_ME_MIN_32_CHARS_REQUIRED_HERE
NEXTAUTH_URL=http://localhost:3000

# ── pgAdmin ───────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@universidadx.com
PGADMIN_PASSWORD=CHANGE_ME
PGADMIN_PORT=5050

# ── Mongo Express ─────────────────────────────────────────────────────
ME_USER=admin
ME_PASSWORD=CHANGE_ME
ME_PORT=8082

# ── Credenciales (Open Badges) ────────────────────────────────────────
ISSUER_URL=https://universidadx.com
ISSUER_NAME=Universidad X

# ── Email (producción) ────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@universidadx.com

# ── Firebase Cloud Messaging ──────────────────────────────────────────
FCM_SERVER_KEY=CHANGE_ME

# ── Staging / CD ─────────────────────────────────────────────────────
# STAGING_HOST=staging.universidadx.com
# STAGING_USER=deploy
# STAGING_SSH_KEY=...
